{
  "name": "bes3-tech-reviews",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Best tech reviews, expert analysis, and buying guides for 2025",
  "keywords": [
    "tech reviews",
    "product reviews",
    "buying guides",
    "technology",
    "AI tools",
    "smart home",
    "VPN reviews",
    "tech news"
  ],
  "author": "Bes3.com Editorial Team",
  "license": "MIT",
  "homepage": "https://bes3.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/bes3/tech-reviews.git"
  },
  "bugs": {
    "url": "https://github.com/bes3/tech-reviews/issues"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "scripts": {
    "dev": "vite --host",
    "build": "tsc && vite build",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint . --ext ts,tsx --fix",
    "preview": "vite preview --host",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prebuild": "npm run clean && npm run type-check",
    "postbuild": "npm run generate-sitemap",
    "generate-sitemap": "node scripts/generate-sitemap.js",
    "analyze": "npm run build && npx vite-bundle-analyzer dist/stats.html",
    "test": "echo \"No tests specified\" && exit 0"
  },
  "dependencies": {
    "lucide-react": "^0.344.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-helmet-async": "^2.0.4",
    "react-router-dom": "^6.20.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.1",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.18",
    "eslint": "^9.9.1",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.11",
    "globals": "^15.9.0",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.3.0",
    "vite": "^5.4.2",
    "vite-plugin-pwa": "^0.17.4"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}