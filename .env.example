# Environment Variables Example
# Copy this file to .env.local and fill in your values

# Site Configuration
VITE_SITE_URL=https://bes3.com
VITE_SITE_NAME=Bes3.com
VITE_SITE_DESCRIPTION=Best tech reviews, expert analysis, and buying guides for 2025

# API Configuration
VITE_API_BASE_URL=https://api.bes3.com
VITE_API_VERSION=v1

# Analytics
VITE_GA_TRACKING_ID=
VITE_GTM_ID=

# External Services
VITE_PEXELS_API_KEY=
VITE_UNSPLASH_ACCESS_KEY=

# Feature Flags
VITE_ENABLE_PWA=true
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_SERVICE_WORKER=true

# Performance
VITE_ENABLE_PRELOAD=true
VITE_ENABLE_LAZY_LOADING=true
VITE_IMAGE_OPTIMIZATION=true

# Development
VITE_DEBUG_MODE=false
VITE_SHOW_PERFORMANCE_METRICS=false

# Contact Form
VITE_CONTACT_FORM_ENDPOINT=
VITE_NEWSLETTER_ENDPOINT=

# Social Media
VITE_FACEBOOK_APP_ID=
VITE_TWITTER_SITE=@bes3tech

# SEO
VITE_DEFAULT_OG_IMAGE=https://bes3.com/og-image.jpg
VITE_TWITTER_CARD=summary_large_image

# Security
VITE_CSP_REPORT_URI=
VITE_SENTRY_DSN=

# Deployment
VITE_VERCEL_URL=
VITE_VERCEL_ENV=
VITE_VERCEL_GIT_COMMIT_SHA=