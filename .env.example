# Local development runtime
NODE_ENV=development
PORT=3000
HOSTNAME=0.0.0.0
NEXT_PUBLIC_APP_URL=http://localhost:3000
JWT_SECRET=dev-only-jwt-secret-change-me-before-production

# Default admin bootstrap
DEFAULT_ADMIN_USERNAME=autobes3
DEFAULT_ADMIN_EMAIL=admin@bes3.local
DEFAULT_ADMIN_PASSWORD=replace-with-a-random-admin-password-before-first-run

# Database
# If DATABASE_URL is set, PostgreSQL is used.
# Otherwise the app falls back to SQLite at DATABASE_PATH.
DATABASE_URL=
DATABASE_PATH=./data/bes3.db

# Media storage
# local: persist to ./storage/media during development
# s3: persist to object storage and expose from MEDIA_PUBLIC_BASE_URL
MEDIA_DRIVER=local
MEDIA_LOCAL_ROOT=storage/media
MEDIA_PUBLIC_BASE_URL=

# S3 / MinIO / R2 compatible object storage
S3_ENDPOINT=
S3_REGION=auto
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_FORCE_PATH_STYLE=false

# PartnerBoost affiliate sync
PARTNERBOOST_AMAZON_BASE_URL=https://app.partnerboost.com
PARTNERBOOST_AMAZON_TOKEN=
PARTNERBOOST_DTC_BASE_URL=https://app.partnerboost.com
PARTNERBOOST_DTC_TOKEN=

# Gemini AI generation
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Scraping / publishing
PLAYWRIGHT_HEADLESS=true
PINGOMATIC_ENABLED=false

# Background pipeline worker
PIPELINE_WORKER_ENABLED=true
PIPELINE_WORKER_POLL_MS=2500
PIPELINE_WORKER_CONCURRENCY=1
