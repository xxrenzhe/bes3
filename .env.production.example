# Bes3 production runtime template for https://bes3.com
# Copy to .env.production on the server, then fill every placeholder before boot.
# Do not commit the filled .env.production file.

NODE_ENV=production
PORT=80
HOSTNAME=0.0.0.0
NEXT_PUBLIC_APP_URL=https://bes3.com
BES3_ALLOWED_HOSTS=bes3.com,www.bes3.com,localhost,localhost:3000,127.0.0.1,127.0.0.1:3000

# Replace with a strong random secret, at least 32 characters.
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-chars

# Default admin bootstrap. Rotate the password immediately after first login.
DEFAULT_ADMIN_USERNAME=autobes3
DEFAULT_ADMIN_EMAIL=admin@bes3.com
DEFAULT_ADMIN_PASSWORD=replace-with-a-random-admin-password-before-first-run

# Production database: use managed PostgreSQL.
DATABASE_URL=postgres://user:password@db.example.com:5432/bes3
DATABASE_PATH=./data/bes3.db

# Production media: use managed object storage.
MEDIA_DRIVER=s3
MEDIA_LOCAL_ROOT=storage/media
MEDIA_PUBLIC_BASE_URL=https://cdn.bes3.com/media
S3_ENDPOINT=https://s3.example.com
S3_REGION=auto
S3_BUCKET=bes3-prod-media
S3_ACCESS_KEY_ID=replace-me
S3_SECRET_ACCESS_KEY=replace-me
S3_FORCE_PATH_STYLE=false

# Affiliate sync
PARTNERBOOST_AMAZON_BASE_URL=https://app.partnerboost.com
PARTNERBOOST_AMAZON_TOKEN=replace-me
PARTNERBOOST_DTC_BASE_URL=https://app.partnerboost.com
PARTNERBOOST_DTC_TOKEN=replace-me

# AI engine
GEMINI_API_KEY=replace-me
GEMINI_MODEL=gemini-3-flash-preview

# Scraping, proxy pool, and pSEO publishing
PLAYWRIGHT_HEADLESS=true
PINGOMATIC_ENABLED=false
BROWSER_PROXY_URLS_JSON=[{"country":"US","url":"http://user:pass@proxy.example.com:1000"}]
DEEP_PRODUCT_SCRAPE_ENABLED=true
DEEP_PRODUCT_SCRAPE_TIMEOUT_MS=60000
DEEP_PRODUCT_SCRAPE_WAIT_AFTER_LOAD_MS=1500
DEEP_PRODUCT_SCRAPE_MAX_ATTEMPTS=2
DEEP_PRODUCT_SCRAPE_REQUIRE_PROXY=true

# Search/indexing
GOOGLE_INDEXING_ENABLED=false
GOOGLE_SERVICE_ACCOUNT_JSON=
PRICE_ALERT_WEBHOOK_URL=

# Background worker
PIPELINE_WORKER_ENABLED=true
PIPELINE_WORKER_ID=
PIPELINE_WORKER_POLL_MS=2500
PIPELINE_WORKER_CONCURRENCY=1
