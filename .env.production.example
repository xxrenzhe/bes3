# Production runtime
NODE_ENV=production
PORT=80
HOSTNAME=0.0.0.0
NEXT_PUBLIC_APP_URL=https://bes3.example.com
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-chars

# Default admin bootstrap
DEFAULT_ADMIN_USERNAME=autobes3
DEFAULT_ADMIN_EMAIL=admin@bes3.local
# Replace before the first production boot.
DEFAULT_ADMIN_PASSWORD=replace-with-a-random-admin-password-before-first-run

# Database
# Single-node deployment: keep SQLite on the persistent /app/data volume.
# Multi-instance deployment: set DATABASE_URL and leave DATABASE_PATH as-is or blank.
DATABASE_URL=
DATABASE_PATH=/app/data/bes3.db

# Media storage
# Single-node deployment: keep MEDIA_DRIVER=local with the mounted storage/media volume.
# Multi-instance deployment: switch to s3 and fill the S3 fields below.
MEDIA_DRIVER=local
MEDIA_LOCAL_ROOT=storage/media
MEDIA_PUBLIC_BASE_URL=

# S3 / MinIO / R2 compatible object storage
S3_ENDPOINT=
S3_REGION=auto
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_FORCE_PATH_STYLE=false

# PartnerBoost affiliate sync
PARTNERBOOST_AMAZON_BASE_URL=https://app.partnerboost.com
PARTNERBOOST_AMAZON_TOKEN=
PARTNERBOOST_DTC_BASE_URL=https://app.partnerboost.com
PARTNERBOOST_DTC_TOKEN=

# Gemini AI generation
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3-flash-preview

# Scraping / publishing
PLAYWRIGHT_HEADLESS=true
PINGOMATIC_ENABLED=false

# Background pipeline worker
PIPELINE_WORKER_ENABLED=true
PIPELINE_WORKER_POLL_MS=2500
PIPELINE_WORKER_CONCURRENCY=1
